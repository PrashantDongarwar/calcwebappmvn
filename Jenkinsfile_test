
pipeline{

    agent {
        label 'linux'
    }

    tools {
        terraform 'tf-install'
    }

    environment {
        IMAGE_NAME = "prod_ecr:${BUILD_NUMBER}"
        TMPDIR = "/var/lib/jenkins/trivy-tmp"
        TRIVY_CACHE_DIR = "/var/lib/jenkins/trivy-cache"
        Region = "us-west-1"
        my_aws_access = credentials('cluster access')
        cluster_name = "my-cluster-mp"
    }
    stages{
        stage('Checkout'){
            steps{
                echo 'Checking out the code...'
                // Add your checkout commands here
            }
        }
        stage('Source Analysis'){
            steps{
                echo 'Analyzing source code...'
                // Add your source analysis commands here
            }
        }
        stage('Build artifacts'){
            steps{
                sh 'ls -la'
                sh 'mvn clean'
                sh 'mvn package'
                echo "Maven Package Goal Executed Successfully!";
                sh 'ls -la'
            }
        }
        stage('Build Docker Image'){
            steps{
                sh 'which docker'
                sh 'docker --version'
                sh 'docker ps'
                sh 'docker images'
                //sh 'docker rmi -f ${docker images -q}'
                //docker system prune -a
                // sh 'docker build -t calcwebappmvn:v1 .' 
                sh 'docker build -t ${IMAGE_NAME} .'
                echo "Docker Image Built Successfully!!"
                sh 'docker images'
            }
        }
        //stage('Trivy Scan'){
        //    steps{
        //        sh 'mkdir -p $TMPDIR $TRIVY_CACHE_DIR'
        //        sh 'trivy image ${IMAGE_NAME}'
        //        echo "Trivy Security Scan Completed Successfully!!"
        //    }
        //}
        stage('ECR Login'){
            steps{
                sh 'aws ecr get-login-password --region us-west-1 | docker login --username AWS --password-stdin 382975714386.dkr.ecr.us-west-1.amazonaws.com'
                echo "Logged in to ECR Successfully!!"

                sh 'docker tag ${IMAGE_NAME} 382975714386.dkr.ecr.us-west-1.amazonaws.com/${IMAGE_NAME}'
                echo "Docker Image Tagged Successfully!!"
                sh 'docker images'
            }
        }
        stage('Push to ECR'){
            steps{
                sh 'docker push 382975714386.dkr.ecr.us-west-1.amazonaws.com/${IMAGE_NAME}'
                echo "Docker Image Pushed to ECR Successfully!!"
            }
        }
        stage('kubeconfig setup') {
            steps {
                sh 'aws eks update-kubeconfig --region ${Region} --name ${cluster_name}'
                // sh '''kubectl create secret docker-registry my-ecr-secret-cbz \
                //       --docker-server=964742912902.dkr.ecr.${Region}.amazonaws.com \
                //       --docker-username=AWS \
                //       --docker-password=$(aws ecr get-login-password --region ${Region})'''

                
                echo "Kubeconfig setup and secret creation completed successfully!!"
            }
        }

        stage('get all resources') {
            steps {

                sh 'kubectl get all'
                sh 'kubectl get secrets'
                echo "Verified access to EKS cluster successfully!!"

                //sh 'kubectl apply -f k8s-deployment.yaml'
                //echo "Application Deployed to EKS Successfully!!"
            }
        }

        stage('Deploy to EKS') {
            steps{
                sh 'sed -i "s#image:.*#image: 382975714386.dkr.ecr.us-west-1.amazonaws.com/${IMAGE_NAME}#g" calc-deployment-svc.yaml'
                sh 'kubectl apply -f calc-deployment-svc.yaml'
                sh 'kubectl get all'
                sh 'sleep 20'
                sh 'kubectl get svc -o wide'
                echo ".war application deployed to EKS cluster successfully!!"
            }
        }
    }
    



    post {   
        success {
            echo 'pipeline is successful'
        }
        failure {
            echo 'pipeline is FAILED'
        }
        always {
            echo 'pipeline is completed'
            cleanWs()
        }
    }
    
}
